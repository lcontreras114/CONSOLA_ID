# ── Security ──────────────────────────────────────────
# CAMBIA ESTO EN PRODUCCIÓN - usa una cadena aleatoria larga
SECRET_KEY=auditsa-super-secret-key-change-in-production-2024

# Duración de sesión en horas
SESSION_EXPIRE_HOURS=8

# ── Cache ─────────────────────────────────────────────
# TTL del cache de Google Sheets en segundos (300 = 5 min)
CACHE_TTL_SECONDS=300

